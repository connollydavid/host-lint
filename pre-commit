#!/bin/bash
# pre-commit hook for host-lint
# Installs as .git/hooks/pre-commit or .git/hooks/commit-msg

# pipefail so a failed `git show` in the staged-blob pipe propagates (rc != 0) and
# the gate fails closed, rather than the linter seeing empty stdin and exiting 0.
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BINARY="$SCRIPT_DIR/host-lint"
# The reproducible asset is named host-lint on Linux/macOS and host-lint.exe on
# Windows; accept either so the hook works on the Windows targets CI publishes.
[ -x "$BINARY" ] || BINARY="$SCRIPT_DIR/host-lint.exe"
EXIT_CODE=0

if [ ! -x "$BINARY" ]; then
    echo "host-lint: binary not found or not executable at $SCRIPT_DIR/host-lint[.exe]" >&2
    exit 2
fi

# Git invokes hooks by name with no name argument: pre-commit gets no args,
# commit-msg gets the message file path as $1. Dispatch on the installed name.
# Act on the linter's exit code. rc 1 = confirmed tell (block); rc 3 = warning
# (advisory, print only); rc 0 = clean; anything else (a usage error, a git
# failure, a panic) fails closed — the gate degrades to a block, never a no-op.
act_on_rc() {
    local rc="$1" result="$2" what="$3"
    case "$rc" in
        1) echo "$result" >&2; EXIT_CODE=1 ;;
        3) echo "$result" >&2 ;;
        0) ;;
        *) echo "host-lint: error linting $what (exit $rc); failing closed" >&2; EXIT_CODE=1 ;;
    esac
}

case "$(basename "$0")" in
    pre-commit)
        # NUL-delimited (-z) so a non-ASCII path is delivered raw, not C-quoted by
        # core.quotePath — a quoted name would make `git show ":$file"` fail (and,
        # before pipefail, feed empty stdin to the linter, committing a tell unseen).
        # Process substitution keeps the loop in this shell so EXIT_CODE survives.
        while IFS= read -r -d '' file; do
            [ -n "$file" ] || continue
            # A submodule gitlink (mode 160000) carries no blob to lint; `git show
            # ":$file"` exits 128 on it and, under pipefail, would fail the gate
            # closed (host-lint#18). Skip it. A real blob whose `git show` fails
            # still fails closed below, so the fail-closed hardening is intact.
            [ "$(git ls-files --stage -- "$file" | awk '{print $1}')" = 160000 ] && continue
            # Lint the STAGED content (the bytes being committed), not the
            # working-tree copy: a tell staged then edited out unstaged would
            # otherwise be committed unseen. `--stdin-as` attributes the blob to
            # the real path so extension semantics and .host-lintignore apply.
            result=$(git show ":$file" 2>&1 | "$BINARY" --stdin-as "$file" 2>&1); rc=$?
            act_on_rc "$rc" "$result" "$file"
        done < <(git diff --cached --name-only -z --diff-filter=ACM)
        ;;
    commit-msg)
        msg_file="$1"
        if [ -f "$msg_file" ]; then
            result=$("$BINARY" --stdin < "$msg_file" 2>&1); rc=$?
            act_on_rc "$rc" "$result" "the commit message"
        fi
        ;;
    *)
        echo "host-lint: install this script as .git/hooks/pre-commit or .git/hooks/commit-msg" >&2
        exit 2
        ;;
esac

exit $EXIT_CODE
