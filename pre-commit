#!/bin/bash
# pre-commit hook for no-phase-skill
# Installs as .git/hooks/pre-commit or .git/hooks/commit-msg

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BINARY="$SCRIPT_DIR/no-phase"
EXIT_CODE=0

if [ ! -x "$BINARY" ]; then
    echo "no-phase: binary not found or not executable at $BINARY" >&2
    exit 2
fi

# Git invokes hooks by name with no name argument: pre-commit gets no args,
# commit-msg gets the message file path as $1. Dispatch on the installed name.
case "$(basename "$0")" in
    pre-commit)
        staged_files=$(git diff --cached --name-only --diff-filter=ACM)
        if [ -n "$staged_files" ]; then
            while IFS= read -r file; do
                if [ -f "$file" ]; then
                    result=$("$BINARY" "$file" 2>&1); rc=$?
                    # rc 1 = confirmed tell (block); rc 3 = warning (advisory, print only)
                    if [ $rc -eq 1 ]; then
                        echo "$result" >&2
                        EXIT_CODE=1
                    elif [ $rc -eq 3 ]; then
                        echo "$result" >&2
                    fi
                fi
            done <<< "$staged_files"
        fi
        ;;
    commit-msg)
        msg_file="$1"
        if [ -f "$msg_file" ]; then
            result=$("$BINARY" --stdin < "$msg_file" 2>&1); rc=$?
            # rc 1 = confirmed tell (block); rc 3 = warning (advisory, print only)
            if [ $rc -eq 1 ]; then
                echo "$result" >&2
                EXIT_CODE=1
            elif [ $rc -eq 3 ]; then
                echo "$result" >&2
            fi
        fi
        ;;
    *)
        echo "no-phase: install this script as .git/hooks/pre-commit or .git/hooks/commit-msg" >&2
        exit 2
        ;;
esac

exit $EXIT_CODE
